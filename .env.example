# Copy this file to .env and fill in real values. Never commit .env.

# Groq (conversational AI)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b

# Twilio (telephony)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15005550006
# Set to false only for local testing without a real Twilio signature.
VALIDATE_TWILIO_SIGNATURE=true

# Public HTTPS URL of this app (e.g. your ngrok tunnel), used when
# constructing webhook callback URLs.
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# SQLite file path
DATABASE_PATH=callsaathi.db

LOG_LEVEL=INFO

# "development" (default) gets pretty console logs; "production" gets
# single-line JSON logs, suited to a log aggregator.
ENV=development

# Optional. Error tracking via Sentry (https://sentry.io - free tier is
# fine). Leave blank to skip Sentry entirely; a warning is logged, nothing
# crashes. Get a DSN by creating a free Sentry account/project and copying
# the DSN from Project Settings -> Client Keys.
SENTRY_DSN=

# Shared secret for GET /internal/stats, e.g. curl -H "X-Internal-Token: <this>" .../internal/stats
# Pick any long random string. Leave blank to disable the endpoint entirely
# (it fails closed, returning 404, rather than being open with no token set).
INTERNAL_STATS_TOKEN=

# How long (seconds) a call's conversation session is kept in call_sessions
# before it's treated as abandoned and expired. 600 (10 min) is generous
# for one phone call. No setup needed - this reuses DATABASE_PATH above
# (see README's "Session state" section for why SQLite rather than Redis).
SESSION_TTL_SECONDS=600

# Notifications: "mock" (default) logs what WOULD be sent to the owner/
# customer instead of actually sending it - safe for local dev. "live"
# sends real SMS via Twilio's Messaging API using the TWILIO_* credentials
# above, and each one is a real, billed message. Only switch to "live" once
# you're ready to test/use real sends (see README's "Notifications" section
# for a step-by-step safe first test). WhatsApp is not implemented yet -
# Twilio's WhatsApp Sandbox requires each recipient to opt in with a join
# code (unworkable for real customers), and production WhatsApp needs Meta
# Business Manager verification not yet done; can be added later behind the
# same NotificationService interface once that's sorted out.
NOTIFICATION_MODE=mock

# Phone number (E.164, e.g. +919876543210) that owner notifications (full
# call transcript + booking details) are sent to in NOTIFICATION_MODE=live.
# Required for owner notifications to actually go anywhere in live mode -
# there's currently no separate "owner's phone" field in the business data
# (businesses.phone_number is the Twilio number customers call, not a phone
# the owner carries), so this one env var is the owner's contact number for
# every business until that's modeled properly.
OWNER_NOTIFICATION_PHONE=

# Optional safety guardrail for NOTIFICATION_MODE=live: comma-separated
# E.164 phone numbers (e.g. +919876543210,+911234567890) that
# TwilioSMSNotificationService will actually text. Any other recipient
# (owner or customer) is skipped, with a logged reason, instead of sent to -
# protects against accidentally texting a real stranger while testing live
# with real calls. Leave blank/unset once ready for real pilot use - an
# empty allowlist sends to anyone.
NOTIFICATION_ALLOWLIST=
