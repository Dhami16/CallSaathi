# Copy this file to .env and fill in real values. Never commit .env.

# Groq (conversational AI)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b

# Twilio (telephony)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15005550006
# Set to false only for local testing without a real Twilio signature.
VALIDATE_TWILIO_SIGNATURE=true

# Public HTTPS URL of this app (e.g. your ngrok tunnel), used when
# constructing webhook callback URLs.
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# SQLite file path
DATABASE_PATH=callsaathi.db

LOG_LEVEL=INFO
