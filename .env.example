# Copy this file to .env and fill in real values. Never commit .env.

# Groq (conversational AI)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b

# Twilio (telephony)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15005550006
# Set to false only for local testing without a real Twilio signature.
VALIDATE_TWILIO_SIGNATURE=true

# Public HTTPS URL of this app (e.g. your ngrok tunnel), used when
# constructing webhook callback URLs.
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# SQLite file path
DATABASE_PATH=callsaathi.db

LOG_LEVEL=INFO

# "development" (default) gets pretty console logs; "production" gets
# single-line JSON logs, suited to a log aggregator.
ENV=development

# Optional. Error tracking via Sentry (https://sentry.io - free tier is
# fine). Leave blank to skip Sentry entirely; a warning is logged, nothing
# crashes. Get a DSN by creating a free Sentry account/project and copying
# the DSN from Project Settings -> Client Keys.
SENTRY_DSN=

# Shared secret for GET /internal/stats, e.g. curl -H "X-Internal-Token: <this>" .../internal/stats
# Pick any long random string. Leave blank to disable the endpoint entirely
# (it fails closed, returning 404, rather than being open with no token set).
INTERNAL_STATS_TOKEN=

# How long (seconds) a call's conversation session is kept in call_sessions
# before it's treated as abandoned and expired. 600 (10 min) is generous
# for one phone call. No setup needed - this reuses DATABASE_PATH above
# (see README's "Session state" section for why SQLite rather than Redis).
SESSION_TTL_SECONDS=600
